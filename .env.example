# Bittensor
BT_NETWORK=finney
NETUID=81
BT_WALLET_NAME=default
BT_HOTKEY=default

# R2/S3 Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_ID=reliquary

# Model
CHECKPOINT_PATH=

# Validator HTTP endpoint (overridable via --http-host / --http-port on the CLI)
RELIQUARY_VALIDATOR_HTTP_HOST=0.0.0.0
RELIQUARY_VALIDATOR_HTTP_PORT=8888

# Validator ingress/admission. Keep backward drand tolerance at zero when the
# signed upload-precommit protocol is deployed to miners.
DRAND_ROUND_BACKWARD_TOLERANCE=0
RELIQUARY_MATH_ADMISSION_WORKERS=4
RELIQUARY_CODE_ADMISSION_WORKERS=2

# Optional
HF_TOKEN=
