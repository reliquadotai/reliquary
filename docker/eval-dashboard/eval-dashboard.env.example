RELIQUARY_VALIDATOR_URL=https://validator.example
RELIQUARY_EVAL_PRODUCER_REVISION=<deployed-40-hex-reliquary-commit>

RELIQUARY_EVAL_R2_ACCOUNT_ID=<cloudflare-account-id>
RELIQUARY_EVAL_R2_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
RELIQUARY_EVAL_R2_ACCESS_KEY_ID=<write-key-id>
RELIQUARY_EVAL_R2_SECRET_ACCESS_KEY=<write-secret>
RELIQUARY_EVAL_R2_BUCKET=reliquary
RELIQUARY_EVAL_R2_REGION=auto

# Optional: receives JSON for failed or overdue evaluations.
RELIQUARY_EVAL_ALERT_WEBHOOK=
