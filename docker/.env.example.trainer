# Bittensor
BT_NETWORK=finney
BT_NETUID=81
BT_WALLET_NAME=subnet
BT_HOTKEY=hotkey1

# Trainer mode
RELIQUARY_TRAIN=1
RELIQUARY_CHECKPOINT=Qwen/Qwen3.5-2B
RELIQUARY_HF_REPO_ID=your-org/reliquary-sn
RELIQUARY_HTTP_HOST=0.0.0.0
RELIQUARY_HTTP_PORT=8080
# Optional — advertise on-chain so miners can discover the validator via metagraph:
# RELIQUARY_EXTERNAL_IP=1.2.3.4
# RELIQUARY_EXTERNAL_PORT=8080
# Optional — resume from a prior checkpoint so restart doesn't reset miners:
# RELIQUARY_RESUME_FROM=sha:fa53996ed1533fadfc86be0e6158ddd8465acf34
# RELIQUARY_RESUME_FROM=path:/state/checkpoints/ckpt_7

# Training stability controls. A fixed KL reference must use an immutable
# 40-character Hugging Face revision and an explicitly selected beta.
# RELIQUARY_KL_BASE_MODEL=Qwen/Qwen3.5-2B@15852e8c16360a2fea060d615a32b45270f8a8fc
# RELIQUARY_KL_BETA=0.004
# RELIQUARY_LEARNING_RATE=0.000002
# RELIQUARY_RECOMPUTE_PI_OLD_FROM_VERIFY=true
# RELIQUARY_GRAD_NORM_SKIP_THRESHOLD=100
# Fraction of completion tokens allowed outside PPO's [0.8, 1.2] ratio band.
# A value of 1 disables this circuit breaker; recovery canaries should calibrate
# and set a lower explicit ceiling.
# RELIQUARY_PPO_RATIO_OUTSIDE_CLIP_SKIP_THRESHOLD=1.0
# Validator-only advantage shaping; zero disables the shaping intervention.
# RELIQUARY_SHAPE_PENALTY=0.5
# RELIQUARY_SHAPE_LEN_FRAC=0.5
# Change this identity only when deliberately starting a fresh training run.
# RELIQUARY_TRAINING_RUN_ID=training-run-20260716
# Stop automatically after publishing this checkpoint; zero means unlimited.
# RELIQUARY_TRAIN_UNTIL_CHECKPOINT_N=0

# Emergency freeze: validation, scoring, archive publishing, and weight setting
# stay live while optimizer steps and checkpoint publication are disabled.
# RELIQUARY_DISABLE_TRAIN=1

# HuggingFace (write access to RELIQUARY_HF_REPO_ID)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# R2 (write access — trainer archives windows + reads for bootstrap)
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET_ID=reliquary
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_ENDPOINT_URL=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.cloudflarestorage.com
